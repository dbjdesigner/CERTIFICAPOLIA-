rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPING MODE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system centered around 
     * a "Master User" (Mestre) paradigm. It prioritizes strict authorization (who can access what) 
     * while maintaining schema flexibility for rapid prototyping.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the requesting user has a specific permission in their profile. */
    function hasPermission(permission) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny([permission]);
    }

    /** @description Checks if the requesting user is a "Master User" (Mestre). */
    function isMaster() {
      return hasPermission('can_manage_users');
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User collection.
     * Allow read for everyone during prototype to enable "First Access" email verification.
     */
    match /users/{userId} {
      allow read, list: if true; 
      allow create: if (isMaster() || (isSignedIn() && request.resource.data.id == request.auth.uid));
      allow update: if (isOwner(userId) || isMaster());
      allow delete: if isMaster();
    }

    /**
     * @description Rules for Role definitions.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create: if isMaster();
      allow update, delete: if isMaster();
    }

    /**
     * @description Rules for Quality Reports.
     */
    match /reports/{reportId} {
      allow get: if isSignedIn() && (isMaster() || resource.data.technicianId == request.auth.uid);
      allow list: if isSignedIn() && (isMaster() || (request.query.limit <= 100 && resource.data.technicianId == request.auth.uid));
      allow create: if hasPermission('can_create_report');
      allow update: if isSignedIn() && (isMaster() || resource.data.technicianId == request.auth.uid);
      allow delete: if isMaster();
    }
  }
}