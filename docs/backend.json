
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user account with roles and permissions.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roleId": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "roleId", "isActive", "createdAt", "updatedAt"]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Defines permissions for user roles.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "description", "permissions"]
    },
    "QualityReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QualityReport",
      "type": "object",
      "description": "A technical quality report for CVT units.",
      "properties": {
        "id": { "type": "string" },
        "reportNumber": { "type": "string" },
        "equipmentType": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "client": { "type": "string" },
        "seller": { "type": "string" },
        "value": { "type": "string" },
        "operationType": { "type": "string", "enum": ["recovery", "sale"] },
        "status": { "type": "string", "enum": ["Budget", "InRecovery", "Published", "Archived"] },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "data": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and permissions."
        }
      },
      {
        "path": "/roles/{roleId}",
        "definition": {
          "entityName": "Role",
          "schema": { "$ref": "#/backend/entities/Role" },
          "description": "Role definitions."
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "QualityReport",
          "schema": { "$ref": "#/backend/entities/QualityReport" },
          "description": "Collection of quality reports."
        }
      }
    ]
  }
}
