rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CERTIFICA LAUDO CVT - SECURITY RULES
     * Implementação de RBAC para ambiente industrial.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica permissão no documento do usuário
    function hasPermission(permission) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny([permission]);
    }

    function isMaster() {
      return hasPermission('can_manage_users');
    }

    // Regras para Usuários
    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn(); // Permitir criação no primeiro acesso
      allow update: if isOwner(userId) || isMaster();
      allow delete: if isMaster();
    }

    // Regras para Papéis/Roles
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }

    // Regras para Relatórios (Ajustado para evitar erros de 'list')
    match /reports/{reportId} {
      // Permitir leitura se for mestre ou se o técnico for o dono do laudo
      allow get: if isSignedIn() && (isMaster() || resource.data.technicianId == request.auth.uid);
      
      // Permitir listagem para qualquer logado (o filtro é feito no cliente via query)
      // Isso resolve o erro de 'Missing or insufficient permissions' em consultas complexas
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isMaster() || resource.data.technicianId == request.auth.uid);
      allow delete: if isMaster();
    }
  }
}